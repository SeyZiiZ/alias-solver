{
  "name": "alias-solver",
  "version": "1.0.0",
  "description": "Convert relative imports to alias-based imports automatically — and back. Auto-detects tsconfig, vite, and webpack alias configs.",
  "bin": {
    "alias-solver": "bin/alias-solver.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "keywords": [
    "imports",
    "alias",
    "relative-imports",
    "tsconfig",
    "paths",
    "vite",
    "webpack",
    "refactor",
    "codemod",
    "typescript",
    "javascript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeyZiiZ/alias-solver.git"
  },
  "homepage": "https://github.com/SeyZiiZ/alias-solver#readme",
  "bugs": {
    "url": "https://github.com/SeyZiiZ/alias-solver/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/minimist": "^1.2.5"
  }
}
